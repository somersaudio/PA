{
  "name": "pa",
  "version": "1.0.0",
  "private": true,
  "description": "Producer's Assistant — AI-powered Pro Tools control, session management, and music production toolkit for macOS",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "email": "node scripts/email-daemon.js",
    "dev:all": "concurrently --kill-others \"next dev\" \"node scripts/email-daemon.js\"",
    "electron:dev": "concurrently --kill-others \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder --mac --arm64",
    "electron:start": "electron .",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "postinstall": "node scripts/setup-db.js"
  },
  "build": {
    "appId": "com.pa.producers-assistant",
    "productName": "PA",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "identity": null,
      "artifactName": "PA-${version}-arm64.${ext}",
      "minimumSystemVersion": "12.0"
    },
    "dmg": {
      "title": "PA — Producer's Assistant",
      "artifactName": "PA-${version}-arm64.${ext}"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "node_modules/**/*",
      "public/**/*",
      "scripts/**/*",
      "bin/**/*",
      "data/soundflow-commands.json",
      "soundflow-scripts/**/*",
      "package.json",
      "next.config.ts",
      "drizzle.config.ts",
      "src/db/**/*"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin"
      },
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "public",
        "to": "public"
      },
      {
        "from": "data/soundflow-commands.json",
        "to": "data/soundflow-commands.json"
      }
    ],
    "afterPack": "./electron/after-pack.js",
    "publish": {
      "provider": "github",
      "owner": "somersaudio",
      "repo": "PA"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "imapflow": "^1.2.16",
    "lucide-react": "^1.0.1",
    "mailparser": "^3.9.5",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "node-osc": "^11.3.0",
    "puppeteer-core": "^24.40.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "soundtouchjs": "^0.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
