# Required — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Spotify API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional — iCloud/IMAP email monitoring
IMAP_HOST=imap.mail.me.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Optional — Suno cookie (auto-extracted by the app)
SUNO_COOKIE=
